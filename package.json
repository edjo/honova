{
  "name": "@honova/core",
  "version": "0.0.1",
  "description": "Nest-like framework for Cloudflare Workers powered by Hono with modules, decorators, DI, and typed database middleware.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "hono",
    "nestjs",
    "dependency-injection",
    "decorators",
    "typescript",
    "framework",
    "api"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "hono": "^4.11.7"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2",
    "vitest": "^2.1.8"
  }
}
